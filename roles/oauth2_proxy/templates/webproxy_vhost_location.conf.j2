## configuration for authentication with oauth2_proxy.

# pass information via X-User and X-Email headers to backend,
# requires running with --set-xauthrequest flag
auth_request_set $user   $upstream_http_x_auth_request_user;
auth_request_set $email  $upstream_http_x_auth_request_email;
proxy_set_header X-User  $user;
proxy_set_header X-Email $email;

# if you enabled --pass-access-token, this will pass the token to the backend
auth_request_set $token  $upstream_http_x_auth_request_access_token;
proxy_set_header X-Access-Token $token;

# if you enabled --cookie-refresh, this is needed for it to work with auth_request
auth_request_set $auth_cookie $upstream_http_set_cookie;
add_header Set-Cookie $auth_cookie;

# Some providers create sessions that exceed the 4kb cookie limit, so OAuth2 Proxy
# splits these into multiple parts.
# Nginx normally only copies the first `Set-Cookie` header from the auth_request to the response,
# so if your cookies are larger than 4kb, you will need to extract additional cookies manually.
{% for oauth2_proxy_cookie_part in [1, 2, 3] %}
auth_request_set $auth_cookie_part_{{ oauth2_proxy_cookie_part }} $upstream_cookie_{{ oauth2_proxy_instance_cookie_name }}_{{ oauth2_proxy_cookie_part }};
{% endfor %}

# Extract the cookie attributes from the first Set-Cookie header and append them
# to the remaining parts ($upstream_cookie_* variables only contain the raw cookie content).
if ($auth_cookie ~* "(; .*)") {
{% for oauth2_proxy_cookie_part in [1, 2, 3] %}
    set $auth_cookie_part_{{ oauth2_proxy_cookie_part }}_with_attributes "{{ oauth2_proxy_instance_cookie_name }}_{{ oauth2_proxy_cookie_part }}=$auth_cookie_part_{{ oauth2_proxy_cookie_part }}$1";
{% endfor %}
}

# Send additional Set-Cookie headers now if OAuth2 Proxy split the session cookie.
{% for oauth2_proxy_cookie_part in [1, 2, 3] %}
if ($auth_cookie_part_{{ oauth2_proxy_cookie_part }}) {
    add_header Set-Cookie $auth_cookie_part_{{ oauth2_proxy_cookie_part }}_with_attributes;
}
{% endfor %}
{{ oauth2_proxy_webproxy_config_custom_vhost_location }}
